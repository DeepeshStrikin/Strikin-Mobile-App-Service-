# Strikin Backend — environment configuration
# Copy to ".env". Secrets must live here, never hardcoded in source.

# App
APP_NAME=Strikin API
ENVIRONMENT=development
DEBUG=true

# Database — defaults to local SQLite. For Postgres use e.g.:
# DATABASE_URL=postgresql+psycopg://strikin:strikin@localhost:5432/strikin
DATABASE_URL=sqlite:///./strikin.db

# CORS — comma-separated origins allowed to call the API (Expo dev server etc.)
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000

# Tax (GST) defaults
DEFAULT_GST_RATE_PERCENT=18
GST_HSN_SAC_CODE=999692

# Loyalty
LOYALTY_EARN_RATE=0.05

# Integrations (leave blank in dev) — these are SECRETS, keep them server-side only.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
SENDGRID_API_KEY=
RESTOWORKS_API_KEY=
